// 短链服务产品页 CTA 按钮
.demo-cta
  display block
  padding 18px 24px
  margin 16px 0
  background linear-gradient(135deg, #3eaf7c 0%, #0a5ec5 100%)
  color #fff
  border-radius 10px
  font-size 17px
  font-weight 600
  text-align center
  text-decoration none
  box-shadow 0 4px 14px rgba(62, 175, 124, .25)
  transition transform .2s, box-shadow .2s
  &:hover
    transform translateY(-2px)
    box-shadow 0 6px 20px rgba(62, 175, 124, .4)
    text-decoration none
    color #fff
  &:active
    transform translateY(0)
